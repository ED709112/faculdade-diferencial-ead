{
  "expo": {
    "name": "Faculdade Diferencial EAD",
    "slug": "faculdade-diferencial-ead",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "faculdadediferencial",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.faculdadediferencial.ead"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a56db",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.faculdadediferencial.ead"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a56db",
          "image": "./assets/images/icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para escanear QR codes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
